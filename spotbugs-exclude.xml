<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Kotlin lateinit generates false null-pointer warnings -->
    <Match>
        <Bug pattern="NP_NULL_ON_SOME_PATH,NP_NULL_PARAM_DEREF,RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE,NP_NONNULL_RETURN_VIOLATION"/>
    </Match>
    <!-- Bukkit plugin pattern: storing plugin references is standard -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2,MS_EXPOSE_REP"/>
    </Match>
    <!-- Kotlin collection casts are safe -->
    <Match>
        <Bug pattern="BC_BAD_CAST_TO_ABSTRACT_COLLECTION"/>
    </Match>
    <!-- Kotlin companion object singleton (JavaPlugin.instance = this in onLoad) is intentional -->
    <Match>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
    </Match>
</FindBugsFilter>
