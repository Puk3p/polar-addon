# Normalize line endings to LF on commit
* text=auto eol=lf

# Source files
*.kt    text eol=lf
*.java  text eol=lf
*.xml   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.sh    text eol=lf

# Windows scripts
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary files — never diff or modify
*.jar   binary
*.class binary
*.png   binary
*.jpg   binary
*.gif   binary
*.zip   binary
