#!/usr/bin/env sh
# Pre-commit hook: formatting check + compile before every commit.

echo "[pre-commit] Step 1: Spotless (code formatting)..."
mvn spotless:check -q
if [ $? -ne 0 ]; then
  echo "[pre-commit] Formatting check failed. Run: mvn spotless:apply"
  exit 1
fi

echo "[pre-commit] Step 2: Compile..."
mvn compile -q
if [ $? -ne 0 ]; then
  echo "[pre-commit] Compilation failed — commit aborted."
  exit 1
fi

echo "[pre-commit] OK."
